# ===== APPROVE =====
def approve(update: Update, context: CallbackContext):
    if update.message.from_user.id != ADMIN_ID:
        return

    try:
        user_id = int(context.args[0])
    except:
        update.message.reply_text("Use: /approve USER_ID")
        return

    custom_id = generate_custom_id()

    cursor.execute("UPDATE users SET approved=1, custom_id=? WHERE user_id=?",
                   (custom_id, user_id))
    conn.commit()

    keyboard = [
        ["💰 Direct income", "📊 Level income"],
        ["🔗 Refferal Link", "👥 Team Count"],
        ["🧠 Quiz Compition", "💸 Withdrawal request"],
        ["🛠 Task Karo", "🏆 Rank System"],
        ["📞 Help support"]
    ]

    context.bot.send_message(
        chat_id=user_id,
        text=f"✅ Approved!\nYour ID: {custom_id}\n\nDashboard 👇",
        reply_markup=ReplyKeyboardMarkup(keyboard, resize_keyboard=True)
    )

